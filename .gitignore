cd D:\Ishan\app

# Append secret-related ignores to .gitignore
Add-Content -Path .gitignore -Value "`n# Secrets & Environment`n.env`n*.env`n*.env.local`n!.env.example`napplication-local.properties`napplication-prod.properties`n!application.properties"

# Verify it was added
Get-Content .gitignore | Select-String ".env"
